{
    "name": "webmens-ru/b24-partners-api-php-sdk",
    "description": "PHP SDK for Bitrix24 Partner REST API (sb.api.v1.partner.*)",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Webmens\\B24PartnersApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webmens\\B24PartnersApi\\Tests\\": "tests/"
        }
    }
}
